# ===========================================
# IntentHunt - Environment Variables
# ===========================================

# --- Backend ---

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Reddit OAuth App (https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_REDIRECT_URI=http://localhost:3001/api/auth/reddit/callback
REDDIT_USER_AGENT=IntentHunt/1.0.0

# Anthropic (Claude API)
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Frontend ---

# API URL (leave empty for local dev with Vite proxy)
VITE_API_URL=
